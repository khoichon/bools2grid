<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="0$o]:${gWC3+5*LyH7:h" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="1$JZ)e~4Rme7c_f#Q/X|"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="function display_led(grid: any) {" line1="    /** " line2="    Directly display the boolean grid list to the LED directly. " line3="    @param grid Grid of 5x5 booleans made using lists" line4="    " line5="    " line6=" */" line7="    for (let x = 0; x &lt; 5; x++) {" line8="        for (let y = 0; y &lt; 5; y++) {" line9="            if (grid[x][y]) {" line10="                led.plot(x, y)" line11="            } else {" line12="                led.unplot(x, y)" line13="            }" line14="            " line15="        }" line16="    }" line17="}" numlines="18"></mutation></block></statement></block></xml>